NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Obligatorio en Vercel para rutas API que escriben en Supabase (bonos/lead, contacto, admin, etc.)
SUPABASE_SERVICE_ROLE_KEY=
AUTH_CHALLENGE_SECRET=

# Reservas con Google Calendar (OAuth en servidor; ver /dashboard/configuracion/calendario)
# Google Cloud Console → APIs → activar "Google Calendar API" → Credenciales → OAuth 2.0 (Web).
# URI de redirección autorizada (ejemplo producción):
#   https://TU_DOMINIO/api/admin/google-calendar/callback
# Desarrollo local:
#   http://localhost:3000/api/admin/google-calendar/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# URL base pública del sitio (sin barra final). En local: http://localhost:3000
NEXT_PUBLIC_APP_URL=
# Opcional: si no usas NEXT_PUBLIC_APP_URL, define el callback exacto:
# GOOGLE_OAUTH_REDIRECT_URI=https://TU_DOMINIO/api/admin/google-calendar/callback
# Opcional: cifrado del refresh token (si no se define, se usa AUTH_CHALLENGE_SECRET)
# GOOGLE_OAUTH_TOKEN_SECRET=

# true = los botones/enlaces a /reservar muestran modal (reserva en pruebas); la URL /reservar sigue accesible directamente
# NEXT_PUBLIC_BOOKING_CTA_DISABLED=true

# Opcional A — sincronización automática (~24 h) con Google Places (clave de desarrollador, no la cuenta del negocio):
# GOOGLE_MAPS_API_KEY=
# GOOGLE_BUSINESS_PLACE_ID=
#
# Opcional B — sin API: nota y reseñas a mano (actualizas .env o redeploy cuando quieras):
# SITE_GOOGLE_RATING=4.7
# SITE_GOOGLE_REVIEW_COUNT=48

# Opcional: Postgres directo para aplicar SQL desde la terminal (npm run db:apply).
# En Supabase: Settings → Database → Connection string (usa el pooler si el host directo falla por IPv6).
# DATABASE_URL=postgresql://postgres.[PROJECT_REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres

# Formulario de contacto (envío real sin mailto)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=465
# SMTP_SECURE=true
# SMTP_USER=tu-cuenta@gmail.com
# SMTP_PASS=tu-app-password
# CONTACT_TO_EMAIL=fisioterapia.rocblanc@gmail.com
# CONTACT_CC_EMAIL=viciana84@gmail.com
